# Copy this file to .env.local and fill in the values before running `npm run build`.
# .env.local is gitignored by default — do not commit real values.

# ---------- Database ----------
# Neon Postgres connection string.
# 1. Sign up at https://neon.tech (free tier is enough to start).
# 2. Create a project, copy the "Pooled connection" string for best Vercel compatibility.
# 3. Paste it below. The `?sslmode=require` suffix is required.
DATABASE_URL=

# ---------- Admin panel auth ----------
# Single password-protected admissions login at /admin.
#
# SESSION_SECRET: random string, 32+ chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
#
# ADMIN_PASSWORD_HASH: bcrypt hash of the admin password. Generate with:
#   npm run admin:hash-password -- "your-strong-password"
# Then paste the output line here.
ADMIN_PASSWORD_HASH=

# ---------- Email notifications (Resend) ----------
# 1. Sign up at https://resend.com (free tier: 100 emails/day, 3k/month).
# 2. Create an API key and paste it below.
# 3. Verify your sending domain OR use Resend's onboarding@resend.dev sender
#    while you're testing.
RESEND_API_KEY=
# Verified sender address (must be on a domain you've verified with Resend).
# For local testing you can use: onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev
# Where new-application notifications should land.
ADMIN_EMAIL=eit.jgf2018@gmail.com

# ---------- Site URL (used in email links) ----------
# In production this is your real domain. In dev, http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Image uploads (Vercel Blob) ----------
# Required for the admin gallery drag-and-drop uploader.
# 1. Vercel Dashboard → your project → Storage → "Create Database" → Blob.
# 2. After creation, copy the BLOB_READ_WRITE_TOKEN shown in the "Quickstart"
#    or "Environment Variables" tab and paste it below (and into Vercel's
#    project env vars so production works too).
# Free tier: 1 GB storage + 10 GB bandwidth/month.
BLOB_READ_WRITE_TOKEN=

# ---------- (Optional) Google Form fallback ----------
# Kept for parity with the old setup — remove this whole section once the
# database is live if you don't need a second copy of submissions in a Google
# Sheet. See GOOGLE_FORM_SETUP.md for the walkthrough.
GOOGLE_FORM_ACTION=
GOOGLE_FORM_ENTRY_FIRST_NAME=
GOOGLE_FORM_ENTRY_LAST_NAME=
GOOGLE_FORM_ENTRY_EMAIL=
GOOGLE_FORM_ENTRY_PHONE=
GOOGLE_FORM_ENTRY_DOB=
GOOGLE_FORM_ENTRY_GENDER=
GOOGLE_FORM_ENTRY_ADDRESS=
GOOGLE_FORM_ENTRY_CITY=
GOOGLE_FORM_ENTRY_STATE=
GOOGLE_FORM_ENTRY_PINCODE=
GOOGLE_FORM_ENTRY_COURSE=
GOOGLE_FORM_ENTRY_EDUCATION=
GOOGLE_FORM_ENTRY_CHURCH=
GOOGLE_FORM_ENTRY_PASTOR=
GOOGLE_FORM_ENTRY_TESTIMONY=
GOOGLE_FORM_ENTRY_MOTIVATION=
